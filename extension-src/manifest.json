{
	"manifest_version": 3,
	"name": "EnCube 2026 v1",
	"version": "1.0.0",
	"description": "EnCube 2026 V1 created and designed by Mohammed Thayeeb Shariff (2026)",
	"permissions": [
		"tabs",
		"scripting",
		"sidePanel",
		"storage"
	],
	"host_permissions": [
		"https://enlighten.enphaseenergy.com/*"
	],
	"content_scripts": [
		{
		"matches": ["https://enphase.lightning.force.com/*"],
		"js": ["content.js"],
		"run_at": "document_start"
		}
	],
	"web_accessible_resources":[
		{
		"resources" : ["images/icon-19.png","images/icon-48.png","images/icon-128.png"],
		"matches" :["<all_urls>"]
		}
	],
	"action": {
		"default_popup": "popup.html",
		"default_title": "EnCube"
	},
	"side_panel": {
		"default_path": "tools.html"
	},
	"icons": {
		"48": "images/icon-48.png",
		"128": "images/icon-128.png"
	},
	"background": {
		"service_worker": "background.js",
		"type": "module"
	}
}
