{
  "manifest_version": 3,
  "name": "Email & SFDC Case Generator",
  "version": "1.0.0",
  "description": "Generate professional customer emails and Salesforce case comments with AI assistance",
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://*.salesforce.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Email & SFDC Generator",
    "default_icon": {
      "16": "images/icon-16.svg",
      "48": "images/icon-48.svg",
      "128": "images/icon-128.svg"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "images/icon-16.svg",
    "48": "images/icon-48.svg",
    "128": "images/icon-128.svg"
  }
}
